$club_settings $mol_page
	title \Настройки
	head /
		<= Title $mol_paragraph title \Настройки
	body /
		<= Theme_row $mol_labeler
			title \Тема
			content / <= Lighter $mol_lights_toggle
		<= Token_label $mol_labeler
			title \Токен авторизации
			content / <= Token_input $mol_string
				value? <=> token? \
				hint \Вставьте токен из кук vas3k.club
		<= Token_help $mol_text
			text \Откройте vas3k.club, в DevTools найдите куку **token** и вставьте сюда. Это позволит читать приватные посты и комментарии.

$club $mol_page
	plugins /
		<= Theme $bog_theme_auto
	title \Вастрик.Клуб
	Head null
	body /
		<= Header $mol_view
			sub /
				<= Logo $mol_link
					arg *
						post null
						user null
						bookmarks null
						rooms null
						settings null
						type null
					sub /
						<= Logo_left $mol_paragraph
							title \Вастрик
						<= Logo_img $mol_image
							uri \https://vas3k.club/static/images/logo/logo-128.png
						<= Logo_right $mol_paragraph
							title \Клуб
				<= Menu_compose $mol_link
					uri \https://vas3k.club/create/
					sub /
						<= Compose_icon $mol_icon_pencil
						<= Compose_text $mol_paragraph
							title \Пиши
				<= Menu_bookmarks $mol_link
					arg *
						bookmarks \1
						post null
						user null
						rooms null
						settings null
						type null
					sub /
						<= Bookmarks_icon $mol_icon_bookmark_outline
				<= Menu_avatar $mol_link
					arg *
						user <= current_user_slug \
						post null
						bookmarks null
						rooms null
						settings null
						type null
					sub /
						<= User_avatar $mol_image
							uri <= current_user_avatar \
		<= Main $mol_view
			sub /
				<= Sidebar $club_menu
				<= Content $mol_view
					sub / <= spread $mol_view
		<= Footer $mol_view
			sub /
				<= Footer_left $mol_view
					sub /
						<= Footer_about $mol_link
							uri \https://vas3k.club/docs/about/
							title \О Клубе
						<= Footer_values $mol_link
							uri \https://vas3k.club/docs/values/
							title \Наши ценности
						<= Footer_team $mol_link
							uri \https://vas3k.club/crew/
							title \Команда
						<= Footer_privacy $mol_link
							uri \https://vas3k.club/docs/privacy_policy/
							title \Политика приватности
						<= Footer_contact $mol_link
							uri \https://vas3k.club/docs/contact/
							title \Связаться с нами
						<= Footer_invite $mol_link
							uri \https://vas3k.club/invites/
							title \Пригласить друга
						<= Footer_opensource $mol_link
							uri \https://github.com/vas3k/vas3k.club
							title \Опенсорс
						<= Footer_payment $mol_link
							uri \https://vas3k.club/docs/blocked_dolor/
							title \Оплата из России
						<= Footer_cc $mol_paragraph
							title \CC BY-SA
				<= Footer_right $mol_view
					sub /
						<= Lighter $mol_lights_toggle
	Feed $club_feed
	Settings $club_settings

$club_post $mol_page
	post_type \
	post_slug \
	title <= post_title \
	Head null
	body /
		<= Article $mol_view
			sub /
				<= Article_header $mol_view
					sub <= article_header_content /
				<= Upvote $mol_view
					sub / <= upvotes_label \
				<= Text_body $mol_text
					text <= content_text \
				<= Post_footer $mol_view
					sub /
						<= Footer_avatar $mol_image
							uri <= author_avatar \
						<= Footer_info $mol_view
							sub /
								<= Footer_link $mol_link
									arg * user <= author_slug \
									sub /
										<= Footer_name $mol_paragraph
											title <= author_name \
										<= Footer_position $mol_paragraph
											title <= author_position \
								<= Footer_date $mol_paragraph
									title <= published_date
		<= Comments_section $mol_view
			sub /
				<= Comments_title $mol_view
					sub /
						<= Comments_count $mol_paragraph
							title <= comments_count_label \
				<= Comments_list $mol_list
					rows <= comment_rows /
	Post_title_block $mol_view
		sub /
			<= Post_title_text $mol_paragraph
				title <= post_title
	Post_publicity $mol_paragraph
		title <= publicity_label \
	Post_info $mol_view
		sub /
			<= Post_actions $mol_view
				sub /
					<= Post_date $mol_paragraph
						title <= published_date \
					<= Post_views $mol_paragraph
						title <= views_label \
	Post_author $mol_view
		sub /
			<= Author_link $mol_link
				arg * user <= author_slug \
				sub /
					<= Author_avatar_small $mol_image
						uri <= author_avatar \
					<= Author_name $mol_paragraph
						title <= author_name \
	Room_badge $mol_view
		sub / <= room_label \
	Battle_title $mol_view
		sub /
			<= Battle_side_a $mol_view
				sub /
					<= Battle_side_a_text $mol_paragraph
						title <= battle_side_a \
			<= Battle_vs $mol_view
				sub /
					<= Battle_vs_text $mol_paragraph
						title \или
			<= Battle_side_b $mol_view
				sub /
					<= Battle_side_b_text $mol_paragraph
						title <= battle_side_b \
	Battle_stats $mol_view
		sub /
			<= Battle_stats_args $mol_view
				sub /
					<= Battle_args_a $mol_paragraph
						title <= battle_args_a_label \
					<= Battle_args_b $mol_paragraph
						title <= battle_args_b_label \
			<= Battle_stats_graph $mol_view
				sub /
					<= Battle_graph_a $mol_view
					<= Battle_graph_b $mol_view

$club_comment $mol_view
	comment null
	show_post_link false
	post_title \
	post_type \
	post_slug \
	sub /
		<= Side $mol_view
			sub /
				<= Avatar_link $mol_link
					arg *
						user <= author_slug \
					sub /
						<= Avatar $mol_image
							uri <= author_avatar \
				<= Thread_ruler $mol_view
		<= Header $mol_view
			sub /
				<= Author_block $mol_view
					sub /
						<= Author_link $mol_link
							arg *
								user <= author_slug \
							sub /
								<= Author_name $mol_paragraph
									title <= author_name \
						<= Author_position $mol_paragraph
							title <= author_position \
				<= Post_link_block $mol_view
					sub / <= post_link_content /
				<= Date $mol_paragraph
					title <= created_date \
		<= Rating $mol_view
			sub / <= upvotes_label \
		<= Body $mol_text
			text <= comment_text \
		<= Footer $mol_view
			sub / <= footer_content /
	Post_link_prefix $mol_paragraph
		title \на пост
	Post_link $mol_link
		arg *
			post <= post_arg \
		sub /
			<= Post_link_title $mol_paragraph
				title <= post_title

$mol_icon_arrow_left $mol_icon path \M20,11V13H8L13.5,18.5L12.08,19.92L4.16,12L12.08,4.08L13.5,5.5L8,11H20Z

$club_profile $mol_page
	user_slug \
	title <= user_name \
	head /
		<= Back $mol_link
			arg *
				user null
			sub /
				<= Back_icon $mol_icon_arrow_left
		<= Title $mol_paragraph
			title <= user_name
	body /
		<= Card $mol_view
			sub /
				<= Card_photo $mol_view
					sub /
						<= Card_avatar $mol_image
							uri <= avatar_url \
				<= Card_info $mol_view
					sub /
						<= Card_name_row $mol_view
							sub /
								<= Card_fullname $mol_paragraph
									title <= user_name
								<= Card_nickname $mol_paragraph
									title <= nickname_label \
						<= Card_job $mol_view
							sub /
								<= Card_position $mol_paragraph
									title <= position_label \
						<= Card_location $mol_paragraph
							title <= location_label \
						<= Card_bio $mol_text
							text <= bio_text \
		<= Statuses $mol_view
			sub /
				<= Status_respect $mol_view
					sub /
						<= Respect_number $mol_paragraph
							title <= upvotes_label \
						<= Respect_text $mol_paragraph
							title \плюсиков
				<= Status_membership $mol_view
					sub /
						<= Membership_number $mol_paragraph
							title <= membership_label \
						<= Membership_text $mol_paragraph
							title \в Клубе
				<= Status_comments $mol_view
					sub /
						<= Comments_number $mol_paragraph
							title <= comments_count_label \
						<= Comments_text $mol_paragraph
							title <= comments_text \
				<= Status_posts $mol_view
					sub /
						<= Posts_number $mol_paragraph
							title <= posts_count_label \
						<= Posts_text $mol_paragraph
							title <= posts_text \
		<= Intro_section $mol_view
			sub /
				<= Intro_header $mol_paragraph
					title \Интро
				<= Intro_text $mol_text
					text <= intro_text \
		<= Tags_section $mol_view
			sub /
				<= Tags_header $mol_paragraph
					title \Теги
				<= Tags_list $mol_view
					sub <= tag_rows /

$club_tag $mol_view
	tag null
	sub / <= tag_name \

$club_bookmarks $mol_page
	title \Закладки
	head /
		<= Back $mol_link
			arg * bookmarks null
			sub /
				<= Back_icon $mol_icon_arrow_left
		<= Title $mol_paragraph
			title \Закладки
	body /
		<= Posts $mol_list
			rows <= post_cards /
	foot /
		<= Pager $mol_paginator
			value? <=> page? 1

$club_rooms $mol_page
	title \Комнаты
	room_title*0 \
	room_subtitle*0 \
	room_members*0 \
	head /
		<= Back $mol_link
			arg * rooms null
			sub /
				<= Back_icon $mol_icon_arrow_left
		<= Title $mol_paragraph
			title \Комнаты
	body /
		<= Rooms $mol_list
			rows <= room_rows /
				<= Room*0 $mol_view
					sub /
						<= Room_title*0 $mol_paragraph
							title <= room_title*
						<= Room_subtitle*0 $mol_paragraph
							title <= room_subtitle*
						<= Room_members*0 $mol_paragraph
							title <= room_members*
